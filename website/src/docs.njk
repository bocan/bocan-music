  <h1>Docs</h1>
  <p>
    {{ site.title }} is meant to be obvious. If you're reading this, it
    probably wasn't obvious enough. Sorry. We'll fix that.
  </p>

  <h2 id="getting-started">Getting started</h2>
  <ol>
    <li>Drag {{ site.title }} into <code>/Applications</code>.</li>
    <li>Open it.</li>
    <li>Choose <strong>Library &rarr; Add Folder…</strong> and point at your music.</li>
    <li>Wait while it scans, fingerprints, and reads tags. Watch the spectrum analyser bounce.</li>
    <li>Listen.</li>
  </ol>

  <h2 id="keyboard-shortcuts">Keyboard shortcuts</h2>
  <table>
    <thead><tr><th>Shortcut</th><th>What it does</th></tr></thead>
    <tbody>
      <tr><td><kbd>Space</kbd></td><td>Play / Pause</td></tr>
      <tr><td><kbd>&rarr;</kbd></td><td>Next track</td></tr>
      <tr><td><kbd>&larr;</kbd></td><td>Previous track</td></tr>
      <tr><td><kbd>&uarr;</kbd> / <kbd>&darr;</kbd></td><td>Volume up / down</td></tr>
      <tr><td><kbd>⌘</kbd><kbd>F</kbd></td><td>Search library</td></tr>
      <tr><td><kbd>⌘</kbd><kbd>L</kbd></td><td>Toggle lyrics pane</td></tr>
      <tr><td><kbd>⌘</kbd><kbd>M</kbd></td><td>Toggle mini-player</td></tr>
      <tr><td><kbd>⌘</kbd><kbd>I</kbd></td><td>Get info / tag editor</td></tr>

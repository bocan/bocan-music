      <tr>
        <td>MP1 (MPEG Layer&nbsp;1)</td>
        <td><code>.mp1</code></td>
        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>AAC</td>
        <td><code>.aac</code> <code>.m4a</code> <code>.m4b</code> <code>.mp4</code></td>
        <td>AVFoundation</td>
      </tr>
      <tr>
        <td>OGG Vorbis / Speex / Ogg FLAC</td>

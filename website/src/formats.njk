<div class="container container--narrow">
  <h1>Supported formats</h1>
  <p>
    {{ site.title }} detects audio formats by <strong>magic bytes</strong>,
    not file extensions, so a renamed file plays correctly without any
    guessing. Decoding uses two back-ends:
    <strong>AVFoundation</strong> (Apple's native stack) and
    <strong>FFmpeg</strong> (bundled LGPL build, no GPL codecs).
  </p>

  <h2 id="lossless-pcm">Lossless PCM</h2>
  <table>
    <thead>
      <tr><th>Format</th><th>Extensions</th><th>Engine</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>WAV / RIFF PCM</td>
        <td><code>.wav</code></td>
        <td>AVFoundation</td>
      </tr>
      <tr>
        <td>AIFF / AIFF-C</td>
        <td><code>.aiff</code> <code>.aif</code></td>
        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>AU / SND</td>
        <td><code>.au</code> <code>.snd</code></td>
        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>Wave64</td>
        <td><code>.w64</code></td>
        <td>FFmpeg (removes the 4&nbsp;GB WAV size cap)</td>
      </tr>
      <tr>
        <td>RF64 / Broadcast Wave</td>
        <td><code>.wav</code> <code>.bwf</code></td>
        <td>FFmpeg (identified by magic bytes, not extension)</td>
      </tr>
    </tbody>
  </table>

  <h2 id="lossless-compressed">Lossless compressed</h2>
  <table>
    <thead>
      <tr><th>Format</th><th>Extensions</th><th>Engine</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>FLAC</td>
        <td><code>.flac</code></td>
        <td>AVFoundation (FFmpeg fallback for unusual streams)</td>
      </tr>
      <tr>
        <td>ALAC (Apple Lossless)</td>
        <td><code>.m4a</code> <code>.alac</code> <code>.mp4</code></td>
        <td>AVFoundation</td>
      </tr>
      <tr>
        <td>Monkey's Audio</td>
        <td><code>.ape</code></td>
        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>WavPack</td>
        <td><code>.wv</code></td>
        <td>FFmpeg (lossless, hybrid-lossy, and DSD modes)</td>
      </tr>
    </tbody>
  </table>


        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>AC-3 / Dolby Digital</td>
        <td><code>.ac3</code></td>
        <td>FFmpeg</td>
      </tr>
      <tr>
        <td>DTS</td>
        <td><code>.dts</code></td>
